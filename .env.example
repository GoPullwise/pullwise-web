VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000
VITE_GITHUB_APP_SLUG=pullwise

# Cloudflare Pages recommended production values:
# VITE_APP_URL=https://app.your-domain.com
# VITE_API_BASE_URL=/api
# PULLWISE_API_ORIGIN=https://api.your-domain.com
#
# PULLWISE_API_ORIGIN is read by functions/api/[[path]].js at runtime. It is a
# Pages Function variable, not a browser-exposed Vite setting.
