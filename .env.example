VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080
VITE_GITHUB_APP_SLUG=pullwise

# Cloudflare Workers production values:
# VITE_APP_URL=https://app.your-domain.com
# VITE_API_BASE_URL=/api
# PULLWISE_API_ORIGIN=https://api.your-domain.com
#
# Cloudflare Pages proxy production values, if using functions/api/[[path]].js instead:
# VITE_APP_URL=https://app.your-domain.com
# VITE_API_BASE_URL=/api
# PULLWISE_API_ORIGIN=https://api.your-domain.com
#
# PULLWISE_API_ORIGIN is read by worker.js or functions/api/[[path]].js at runtime.
# It is not a browser-exposed Vite setting.
